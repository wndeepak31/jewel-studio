generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RingStyle {
  id            String   @id @default(cuid())
  name          String
  slug          String   @default("")
  imageUrl      String
  weight14k     Float    @default(0)
  weight18k     Float    @default(0)
  sideStoneWeight Float  @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Shape {
  id           String        @id @default(cuid())
  name         String
  slug         String        @default("")
  imageUrl     String
  isActive     Boolean       @default(true)
  diamondRates DiamondRate[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Setting {
  id               String   @id @default(cuid())
  name             String
  slug             String   @default("")
  imageUrl         String
  priceMultiplier  Float    @default(1.0)
  weight14k        Float    @default(0)
  weight18k        Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Metal {
  id             String   @id @default(cuid())
  name           String   
  purity         String   
  color          String   
  pricePerGram   Float
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Diamond {
  id            String        @id @default(cuid())
  clarity       String
  color         String
  pricePerCarat Float
  isActive      Boolean       @default(true)
  diamondRates  DiamondRate[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CaratOption {
  id           String        @id @default(cuid())
  value        Float
  multiplier   Float         @default(1.0)
  isActive     Boolean       @default(true)
  diamondRates DiamondRate[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GlobalSettings {
  id              String @id @default("global")
  goldRate        Float  @default(0)
  labourRate      Float  @default(2000)
  sideStoneRate   Float  @default(45000)
  taxPercent      Float  @default(3.0)
  profitMargin    Float  @default(10.0)
  discountPercent Float  @default(0)
}

model RingCombinationImage {
  id          String   @id @default(cuid())
  styleSlug   String
  shapeSlug   String
  carat       String
  metal       String
  settingSlug String
  view1Url    String
  view2Url    String   @default("")
  view3Url    String   @default("")
  view4Url    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([styleSlug, shapeSlug, carat, metal, settingSlug])
}

model DiamondRate {
  id            String      @id @default(cuid())
  shapeId       String
  caratOptionId String
  diamondId     String      @default("") // Link to quality (Diamond model)
  rate          Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  shape         Shape       @relation(fields: [shapeId], references: [id])
  caratOption   CaratOption @relation(fields: [caratOptionId], references: [id])
  diamond       Diamond     @relation(fields: [diamondId], references: [id])

  @@unique([shapeId, caratOptionId, diamondId])
}
